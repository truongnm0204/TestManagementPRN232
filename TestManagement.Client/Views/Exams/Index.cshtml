@model TestManagement.Client.Models.Exams.ExamListViewModel
@{
    ViewData["Title"] = "Đề thi";
}

<div class="page-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h4 mb-1">Quản lý đề thi</h1>
            <p class="text-muted mb-0">Tạo đề thi, chọn câu hỏi và publish để chuẩn bị giao cho lớp.</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <a class="btn btn-primary" asp-action="Create">Tạo đề thi</a>
        }
    </div>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3"><input name="keyword" value="@Model.Keyword" class="form-control" placeholder="Tìm tên đề thi" /></div>
        <div class="col-md-3">
            <select name="subjectId" class="form-select">
                <option value="">Tất cả môn học</option>
                @foreach (var subject in Model.Subjects)
                {
                    <option value="@subject.Value" selected="@(Model.SubjectId?.ToString() == subject.Value)">@subject.Text</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="status" class="form-select">
                <option value="">Trạng thái</option>
                <option value="Draft" selected="@(Model.Status == "Draft")">Draft</option>
                <option value="Published" selected="@(Model.Status == "Published")">Published</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="isPublished" class="form-select">
                <option value="">Publish</option>
                <option value="false" selected="@(Model.IsPublished == false)">Chưa publish</option>
                <option value="true" selected="@(Model.IsPublished == true)">Đã publish</option>
            </select>
        </div>
        <div class="col-md-1"><button type="submit" class="btn btn-outline-primary w-100">Tìm</button></div>
        <div class="col-md-1"><a asp-action="Index" class="btn btn-outline-secondary w-100">Mới</a></div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Đề thi</th>
                    <th>Môn học</th>
                    <th>Thời gian</th>
                    <th>Lượt làm</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Không có dữ liệu.</td></tr>
                }
                @foreach (var exam in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@exam.Title</div>
                            <small class="text-muted">Người tạo: @exam.CreatorName</small>
                        </td>
                        <td><span class="fw-semibold">@exam.SubjectCode</span><br /><small class="text-muted">@exam.SubjectName</small></td>
                        <td>@exam.DurationMinutes phút</td>
                        <td>@exam.AttemptLimit</td>
                        <td>
                            <span class="badge @(exam.IsPublished ? "text-bg-success" : "text-bg-secondary")">@exam.Status</span>
                        </td>
                        <td>@exam.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Compose" asp-route-id="@exam.Id">Câu hỏi</a>
                                @if (exam.CanEdit)
                                {
                                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@exam.Id">Sửa</a>
                                }
                            }
                            @if (User.IsInRole("Admin") && exam.CanEdit)
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger js-delete" data-delete-url="@Url.Action("Delete", "Exams", new { id = exam.Id })" data-delete-name="đề thi @exam.Title">Xóa</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <span class="text-muted">Trang @Model.Page @(Model.Count.HasValue ? $"/ Tổng {Model.Count.Value} dòng" : string.Empty)</span>
        <div class="btn-group">
            <a class="btn btn-outline-secondary @(Model.HasPrevious ? string.Empty : "disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-subjectId="@Model.SubjectId" asp-route-status="@Model.Status" asp-route-isPublished="@Model.IsPublished" asp-route-page="@(Model.Page - 1)">Trước</a>
            <a class="btn btn-outline-secondary @(Model.HasNext ? string.Empty : "disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-subjectId="@Model.SubjectId" asp-route-status="@Model.Status" asp-route-isPublished="@Model.IsPublished" asp-route-page="@(Model.Page + 1)">Sau</a>
        </div>
    </div>
</div>

<partial name="_DeleteConfirmationModal" />

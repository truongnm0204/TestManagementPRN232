@model TestManagement.Client.Models.ExamResults.ClassResultViewModel
@{
    ViewData["Title"] = "Kết quả: " + Model.ExamTitle;
}

<div class="page-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h4 mb-1">@Model.ExamTitle</h1>
            <p class="text-muted mb-0">Lớp @Model.ClassName · @Model.QuestionCount câu · Điểm tối đa @Model.MaxScore</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-info" asp-action="Monitor" asp-route-examId="@Model.ExamId" asp-route-classId="@Model.ClassId">Theo dõi trực tiếp</a>
            <a class="btn btn-outline-secondary" asp-action="Index">Về danh sách</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Học viên</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Điểm</th>
                    <th class="text-center">Đúng</th>
                    <th class="text-center">Sai</th>
                    <th>Nộp lúc</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Rows.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Lớp chưa có học viên.</td></tr>
                }
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td class="fw-semibold">@row.StudentName</td>
                        <td>
                            @if (row.HasSubmitted)
                            {
                                <span class="badge text-bg-success">Đã nộp</span>
                            }
                            else if (row.HasInProgress)
                            {
                                <span class="badge text-bg-warning">Đang làm</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Chưa làm</span>
                            }
                        </td>
                        <td class="text-center">@(row.TotalScore.HasValue ? $"{row.TotalScore} / {Model.MaxScore}" : "-")</td>
                        <td class="text-center text-success">@(row.HasSubmitted ? row.CorrectCount.ToString() : "-")</td>
                        <td class="text-center text-danger">@(row.HasSubmitted ? row.WrongCount.ToString() : "-")</td>
                        <td>@(row.SubmittedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td class="text-end">
                            @if (row.AttemptId.HasValue)
                            {
                                <a class="btn btn-sm btn-outline-info" asp-action="History" asp-route-attemptId="@row.AttemptId">Lịch sử</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model TestManagement.Client.Models.Subjects.SubjectListViewModel
@{
    ViewData["Title"] = "Môn học";
}

<div class="page-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h4 mb-1">Quản lý môn học</h1>
            <p class="text-muted mb-0">Tìm kiếm, tạo, cập nhật và xóa môn học.</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createSubjectModal">Tạo môn học</button>
        }
    </div>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-5">
            <input name="keyword" value="@Model.Keyword" class="form-control" placeholder="Tìm theo mã hoặc tên" />
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">Tất cả trạng thái</option>
                <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">Tìm kiếm</button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Làm mới</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã</th>
                    <th>Tên môn học</th>
                    <th>Trạng thái</th>
                    <th>Số câu hỏi</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Không có dữ liệu.</td></tr>
                }
                @foreach (var subject in Model.Items)
                {
                    <tr>
                        <td class="fw-semibold">@subject.Code</td>
                        <td>
                            <div>@subject.Name</div>
                            <small class="text-muted">@subject.Description</small>
                        </td>
                        <td><span class="badge @(subject.Status == "Active" ? "text-bg-success" : "text-bg-secondary")">@subject.Status</span></td>
                        <td>@subject.QuestionCount</td>
                        <td>@subject.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                            {
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="loadSubjectForEdit(@subject.Id)">Sửa</button>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger js-delete" data-delete-url="@Url.Action("Delete", "Subjects", new { id = subject.Id })" data-delete-name="@subject.Code - @subject.Name">Xóa</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <span class="text-muted">Trang @Model.Page @(Model.Count.HasValue ? $"/ Tổng {Model.Count.Value} dòng" : string.Empty)</span>
        <div class="btn-group">
            <a class="btn btn-outline-secondary @(Model.HasPrevious ? string.Empty : "disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Status" asp-route-page="@(Model.Page - 1)">Trước</a>
            <a class="btn btn-outline-secondary @(Model.HasNext ? string.Empty : "disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Status" asp-route-page="@(Model.Page + 1)">Sau</a>
        </div>
    </div>
</div>

@if (User.IsInRole("Admin") || User.IsInRole("Staff"))
{
    <div class="modal fade" id="createSubjectModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form asp-action="Create" method="post" class="modal-content">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h5 class="modal-title">Tạo môn học</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label">Mã môn học</label><input name="Code" class="form-control" required maxlength="50" /></div>
                    <div class="mb-3"><label class="form-label">Tên môn học</label><input name="Name" class="form-control" required maxlength="150" /></div>
                    <div class="mb-3"><label class="form-label">Mô tả</label><textarea name="Description" class="form-control" rows="3" maxlength="1000"></textarea></div>
                    <div class="mb-3"><label class="form-label">Trạng thái</label><select name="Status" class="form-select"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu</button></div>
            </form>
        </div>
    </div>

    <div class="modal fade" id="editSubjectModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form asp-action="Update" method="post" class="modal-content">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editSubjectId" />
                <div class="modal-header"><h5 class="modal-title">Cập nhật môn học</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label">Mã môn học</label><input name="Code" id="editSubjectCode" class="form-control" required maxlength="50" /></div>
                    <div class="mb-3"><label class="form-label">Tên môn học</label><input name="Name" id="editSubjectName" class="form-control" required maxlength="150" /></div>
                    <div class="mb-3"><label class="form-label">Mô tả</label><textarea name="Description" id="editSubjectDescription" class="form-control" rows="3" maxlength="1000"></textarea></div>
                    <div class="mb-3"><label class="form-label">Trạng thái</label><select name="Status" id="editSubjectStatus" class="form-select"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Cập nhật</button></div>
            </form>
        </div>
    </div>
}

<partial name="_DeleteConfirmationModal" />

@section Scripts {
    <script>
        async function loadSubjectForEdit(id) {
            const response = await fetch(`@Url.Action("GetForEdit", "Subjects")?id=${id}`);
            if (!response.ok) {
                alert('Không thể tải thông tin môn học để chỉnh sửa.');
                return;
            }
            const subject = await response.json();
            document.getElementById('editSubjectId').value = subject.id;
            document.getElementById('editSubjectCode').value = subject.code || '';
            document.getElementById('editSubjectName').value = subject.name || '';
            document.getElementById('editSubjectDescription').value = subject.description || '';
            document.getElementById('editSubjectStatus').value = subject.status || 'Active';
            bootstrap.Modal.getOrCreateInstance(document.getElementById('editSubjectModal')).show();
        }
    </script>
}

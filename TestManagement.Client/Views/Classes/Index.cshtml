@model TestManagement.Client.Models.Classes.ClassListViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Lớp học của tôi";
    var currentUserId = int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out var uid) ? uid : 0;
}

<div class="page-card p-4">
    <div class="mb-3">
        <h1 class="h4 mb-1">Lớp học của tôi</h1>
        <p class="text-muted mb-0">Danh sách các lớp bạn đang phụ trách.</p>
    </div>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-6">
            <input name="keyword" value="@Model.Keyword" class="form-control" placeholder="Tìm theo mã hoặc tên lớp" />
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">Tất cả trạng thái</option>
                <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
                <option value="Closed" selected="@(Model.Status == "Closed")">Closed</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">Tìm kiếm</button>
        </div>
        <div class="col-md-1">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Mới</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã lớp</th>
                    <th>Tên lớp</th>
                    <th>Trạng thái</th>
                    <th>Số SV</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Bạn chưa được phân công vào lớp học nào.</td></tr>
                }
                @foreach (var cls in Model.Items)
                {
                    <tr>
                        <td class="fw-semibold">@cls.ClassCode</td>
                        <td>
                            <div>@cls.ClassName</div>
                            @if (!string.IsNullOrWhiteSpace(cls.Description))
                            {
                                <small class="text-muted">@cls.Description</small>
                            }
                        </td>
                        <td>
                            @{
                                var clsBadge = cls.Status switch {
                                    "Active" => ("bg-success text-white", "bi-check-circle-fill", "Active"),
                                    "Closed" => ("bg-danger text-white", "bi-x-circle-fill", "Closed"),
                                    _ => ("bg-secondary text-white", "bi-pause-circle-fill", "Inactive")
                                };
                            }
                            <span class="badge @clsBadge.Item1"><i class="bi @clsBadge.Item2 me-1"></i>@clsBadge.Item3</span>
                        </td>
                        <td>@cls.StudentCount</td>
                        <td>@cls.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <a asp-action="Detail" asp-route-id="@cls.Id" class="btn btn-sm btn-outline-secondary">Chi tiết</a>
                            @if (cls.CreatedBy == currentUserId)
                            {
                                <form asp-action="DissolveClass" method="post" class="d-inline"
                                      onsubmit="return confirm('Giải tán lớp @cls.ClassName? Hành động này không thể hoàn tác.')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="classId" value="@cls.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash3 me-1"></i>Giải tán
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="LeaveClass" method="post" class="d-inline"
                                      onsubmit="return confirm('Rời khỏi lớp @cls.ClassName?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="classId" value="@cls.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-box-arrow-left me-1"></i>Rời lớp
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <span class="text-muted">Trang @Model.Page @(Model.Count.HasValue ? $"/ Tổng {Model.Count.Value} dòng" : string.Empty)</span>
        <div class="btn-group">
            <a class="btn btn-outline-secondary @(Model.HasPrevious ? string.Empty : "disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Status" asp-route-page="@(Model.Page - 1)">Trước</a>
            <a class="btn btn-outline-secondary @(Model.HasNext ? string.Empty : "disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Status" asp-route-page="@(Model.Page + 1)">Sau</a>
        </div>
    </div>
</div>


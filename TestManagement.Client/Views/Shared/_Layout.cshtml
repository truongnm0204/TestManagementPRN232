<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TestManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TestManagement.Client.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="navbar navbar-expand-lg navbar-dark bg-primary app-header">
        <div class="container-fluid">
            <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">TestManagement</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topNavbar" aria-controls="topNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="topNavbar">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @User.Identity.Name (@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Auth" asp-action="Profile">Hồ sơ cá nhân</a></li>
                                <li><a class="dropdown-item" asp-controller="Auth" asp-action="ChangePassword">Đổi mật khẩu</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post" class="px-3">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-link dropdown-item p-0">Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Auth" asp-action="Login">Đăng nhập</a></li>
                    }
                </ul>
            </div>
        </div>
    </header>

    <div class="app-shell">
        @if (User.Identity?.IsAuthenticated == true)
        {
            var _ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
            Func<string, string> _navCls = (ctrl) =>
                string.Equals(_ctrl, ctrl, StringComparison.OrdinalIgnoreCase) ? "nav-link active" : "nav-link";

            <aside class="app-sidebar">
                <nav class="nav flex-column gap-1">
                    <a class="@(_ctrl == "Home" ? "nav-link active" : "nav-link")" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-grid me-2"></i>Tổng quan
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="@(_ctrl == "Users" ? "nav-link active" : "nav-link")" asp-controller="Users" asp-action="Index">
                            <i class="bi bi-people me-2"></i>Người dùng
                        </a>
                        <a class="@(_ctrl == "Classes" ? "nav-link active" : "nav-link")" asp-controller="Classes" asp-action="AdminIndex">
                            <i class="bi bi-building me-2"></i>Lớp học
                        </a>
                    }
                    @if (User.IsInRole("Teacher"))
                    {
                        <a class="@(_ctrl == "Classes" ? "nav-link active" : "nav-link")" asp-controller="Classes" asp-action="Index">
                            <i class="bi bi-building me-2"></i>Lớp học
                        </a>
                    }
                    @if (!User.IsInRole("Teacher"))
                    {
                        <a class="@(_ctrl == "Subjects" ? "nav-link active" : "nav-link")" asp-controller="Subjects" asp-action="Index">
                            <i class="bi bi-book me-2"></i>Môn học
                        </a>
                    }
                    @if (User.IsInRole("Teacher"))
                    {
                        <a class="@(_ctrl == "Questions" ? "nav-link active" : "nav-link")" asp-controller="Questions" asp-action="Packages">
                            <i class="bi bi-question-circle me-2"></i>Câu hỏi
                        </a>
                    }
                    else
                    {
                        <a class="@(_ctrl == "Questions" ? "nav-link active" : "nav-link")" asp-controller="Questions" asp-action="Index">
                            <i class="bi bi-question-circle me-2"></i>Câu hỏi
                        </a>
                    }
                </nav>
            </aside>
        }

        <main class="app-content">
            <div class="container-fluid py-4">
                <partial name="_Alert" />
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="app-footer border-top text-muted">
        <div class="container-fluid py-3">
            &copy; 2026 - TestManagement
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

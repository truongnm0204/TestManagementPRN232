@model List<TestManagement.Client.Models.Questions.SubjectPackageViewModel>
@{
    ViewData["Title"] = "Câu hỏi của tôi";
    var withQuestions = Model.Where(p => p.QuestionCount > 0).ToList();
    var withoutQuestions = Model.Where(p => p.QuestionCount == 0).ToList();
}

<div class="page-card p-4">
    <div class="mb-4">
        <h1 class="h4 mb-1">Câu hỏi của tôi</h1>
        <p class="text-muted mb-0">Chọn môn học để xem và quản lý câu hỏi.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-book fs-1 d-block mb-2"></i>
            Hệ thống chưa có môn học nào.
        </div>
    }
    else
    {
        @if (withQuestions.Any())
        {
            <h6 class="text-muted fw-semibold mb-3 text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">
                <i class="bi bi-check-circle-fill text-success me-1"></i>Đã có câu hỏi (@withQuestions.Count)
            </h6>
            <div class="row g-3 mb-4">
                @foreach (var pkg in withQuestions)
                {
                    <div class="col-md-4 col-lg-3">
                        <a asp-action="BySubject" asp-route-subjectId="@pkg.SubjectId"
                           class="dashboard-card text-decoration-none d-flex flex-column gap-2 p-4 border rounded-3 bg-white h-100">
                            <div class="d-flex align-items-center gap-3">
                                <div class="dashboard-icon bg-primary bg-opacity-10 text-primary rounded-3 p-3">
                                    <i class="bi bi-book fs-4"></i>
                                </div>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-semibold text-truncate">@pkg.SubjectCode</div>
                                    <small class="text-muted text-truncate d-block">@pkg.SubjectName</small>
                                </div>
                            </div>
                            <div class="mt-1">
                                <span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:.85rem;">
                                    <i class="bi bi-question-circle me-1"></i>@pkg.QuestionCount câu hỏi
                                </span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }

        @if (withoutQuestions.Any())
        {
            <h6 class="text-muted fw-semibold mb-3 text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">
                <i class="bi bi-circle me-1"></i>Chưa có câu hỏi (@withoutQuestions.Count)
            </h6>
            <div class="row g-3">
                @foreach (var pkg in withoutQuestions)
                {
                    <div class="col-md-4 col-lg-3">
                        <a asp-action="BySubject" asp-route-subjectId="@pkg.SubjectId"
                           class="dashboard-card text-decoration-none d-flex flex-column gap-2 p-4 border border-dashed rounded-3 bg-white h-100" style="opacity:.7;">
                            <div class="d-flex align-items-center gap-3">
                                <div class="dashboard-icon bg-secondary bg-opacity-10 text-secondary rounded-3 p-3">
                                    <i class="bi bi-book fs-4"></i>
                                </div>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-semibold text-truncate text-secondary">@pkg.SubjectCode</div>
                                    <small class="text-muted text-truncate d-block">@pkg.SubjectName</small>
                                </div>
                            </div>
                            <div class="mt-1">
                                <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size:.85rem;">
                                    Chưa có câu hỏi
                                </span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    }
</div>

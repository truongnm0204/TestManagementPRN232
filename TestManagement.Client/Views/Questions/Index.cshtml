@model TestManagement.Client.Models.Questions.QuestionListViewModel
@{
    ViewData["Title"] = "Câu hỏi";
}

<div class="page-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h4 mb-1">Quản lý câu hỏi</h1>
            <p class="text-muted mb-0">Quản lý câu hỏi multiple choice theo môn học.</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
        {
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createQuestionModal">Tạo câu hỏi</button>
        }
    </div>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3"><input name="keyword" value="@Model.Keyword" class="form-control" placeholder="Tìm nội dung câu hỏi" /></div>
        <div class="col-md-3">
            <select name="subjectId" class="form-select">
                <option value="">Tất cả môn học</option>
                @foreach (var subject in Model.Subjects)
                {
                    <option value="@subject.Value" selected="@(Model.SubjectId?.ToString() == subject.Value)">@subject.Text</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="difficulty" class="form-select">
                <option value="">Độ khó</option>
                <option value="Easy" selected="@(Model.Difficulty == "Easy")">Easy</option>
                <option value="Medium" selected="@(Model.Difficulty == "Medium")">Medium</option>
                <option value="Hard" selected="@(Model.Difficulty == "Hard")">Hard</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="status" class="form-select">
                <option value="">Trạng thái</option>
                <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
            </select>
        </div>
        <div class="col-md-1"><button type="submit" class="btn btn-outline-primary w-100">Tìm</button></div>
        <div class="col-md-1"><a asp-action="Index" class="btn btn-outline-secondary w-100">Mới</a></div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Môn học</th>
                    <th>Nội dung</th>
                    <th>Độ khó</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Không có dữ liệu.</td></tr>
                }
                @foreach (var question in Model.Items)
                {
                    <tr>
                        <td><span class="fw-semibold">@question.SubjectCode</span><br /><small class="text-muted">@question.SubjectName</small></td>
                        <td><div class="text-truncate-2" style="max-width: 520px;">@question.Content</div></td>
                        <td>
                            @{
                                var diffBadge = question.Difficulty switch {
                                    "Easy" => ("bg-success text-white", "bi-emoji-smile-fill", "Easy"),
                                    "Medium" => ("bg-warning text-dark", "bi-emoji-neutral-fill", "Medium"),
                                    "Hard" => ("bg-danger text-white", "bi-emoji-angry-fill", "Hard"),
                                    _ => ("bg-secondary text-white", "bi-question-circle-fill", question.Difficulty)
                                };
                            }
                            <span class="badge @diffBadge.Item1"><i class="bi @diffBadge.Item2 me-1"></i>@diffBadge.Item3</span>
                        </td>
                        <td>
                            @if (question.Status == "Active")
                            {
                                <span class="badge bg-success text-white"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary text-white"><i class="bi bi-pause-circle-fill me-1"></i>Inactive</span>
                            }
                        </td>
                        <td>@question.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                            {
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="loadQuestionForEdit(@question.Id)">Sửa</button>
                                <button type="button" class="btn btn-sm btn-outline-danger js-delete" data-delete-url="@Url.Action("Delete", "Questions", new { id = question.Id })" data-delete-name="câu hỏi #@question.Id">Xóa</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <span class="text-muted">Trang @Model.Page @(Model.Count.HasValue ? $"/ Tổng {Model.Count.Value} dòng" : string.Empty)</span>
        <div class="btn-group">
            <a class="btn btn-outline-secondary @(Model.HasPrevious ? string.Empty : "disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-subjectId="@Model.SubjectId" asp-route-difficulty="@Model.Difficulty" asp-route-status="@Model.Status" asp-route-page="@(Model.Page - 1)">Trước</a>
            <a class="btn btn-outline-secondary @(Model.HasNext ? string.Empty : "disabled")" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-subjectId="@Model.SubjectId" asp-route-difficulty="@Model.Difficulty" asp-route-status="@Model.Status" asp-route-page="@(Model.Page + 1)">Sau</a>
        </div>
    </div>
</div>

@if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
{
    <div class="modal fade" id="createQuestionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <form asp-action="Create" method="post" class="modal-content">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h5 class="modal-title">Tạo câu hỏi</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4"><label class="form-label">Môn học</label><select name="SubjectId" class="form-select" required><option value="">Chọn môn học</option>@foreach (var subject in Model.Subjects) { <option value="@subject.Value">@subject.Text</option> }</select></div>
                        <div class="col-md-4"><label class="form-label">Độ khó</label><select name="Difficulty" class="form-select"><option value="Easy">Easy</option><option value="Medium">Medium</option><option value="Hard">Hard</option></select></div>
                        <div class="col-md-4"><label class="form-label">Trạng thái</label><select name="Status" class="form-select"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div>
                        <div class="col-12"><label class="form-label">Nội dung</label><textarea name="Content" class="form-control" rows="3" required maxlength="2000"></textarea></div>
                        <div class="col-12"><label class="form-label">Giải thích</label><textarea name="Explanation" class="form-control" rows="2" maxlength="2000"></textarea></div>
                    </div>
                    <hr />
                    <h6>Đáp án</h6>
                    @for (var i = 0; i < 4; i++)
                    {
                        var label = ((char)('A' + i)).ToString();
                        <div class="input-group mb-2">
                            <span class="input-group-text">@label</span>
                            <input type="hidden" name="Options[@i].Label" value="@label" />
                            <input type="hidden" name="Options[@i].SortOrder" value="@(i + 1)" />
                            <input name="Options[@i].Content" class="form-control" placeholder="Nội dung đáp án @label" required maxlength="1000" />
                            <span class="input-group-text"><input class="form-check-input mt-0" type="radio" name="CorrectOptionIndex" value="@i" checked="@(i == 0)" /></span>
                        </div>
                    }
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu</button></div>
            </form>
        </div>
    </div>

    <div class="modal fade" id="editQuestionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <form asp-action="Update" method="post" class="modal-content">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editQuestionId" />
                <div class="modal-header"><h5 class="modal-title">Cập nhật câu hỏi</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4"><label class="form-label">Môn học</label><select name="SubjectId" id="editQuestionSubjectId" class="form-select" required><option value="">Chọn môn học</option>@foreach (var subject in Model.Subjects) { <option value="@subject.Value">@subject.Text</option> }</select></div>
                        <div class="col-md-4"><label class="form-label">Độ khó</label><select name="Difficulty" id="editQuestionDifficulty" class="form-select"><option value="Easy">Easy</option><option value="Medium">Medium</option><option value="Hard">Hard</option></select></div>
                        <div class="col-md-4"><label class="form-label">Trạng thái</label><select name="Status" id="editQuestionStatus" class="form-select"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div>
                        <div class="col-12"><label class="form-label">Nội dung</label><textarea name="Content" id="editQuestionContent" class="form-control" rows="3" required maxlength="2000"></textarea></div>
                        <div class="col-12"><label class="form-label">Giải thích</label><textarea name="Explanation" id="editQuestionExplanation" class="form-control" rows="2" maxlength="2000"></textarea></div>
                    </div>
                    <hr />
                    <h6>Đáp án</h6>
                    @for (var i = 0; i < 4; i++)
                    {
                        var label = ((char)('A' + i)).ToString();
                        <div class="input-group mb-2">
                            <span class="input-group-text">@label</span>
                            <input type="hidden" name="Options[@i].Label" value="@label" />
                            <input type="hidden" name="Options[@i].SortOrder" value="@(i + 1)" />
                            <input name="Options[@i].Content" id="editOptionContent@i" class="form-control" placeholder="Nội dung đáp án @label" required maxlength="1000" />
                            <span class="input-group-text"><input class="form-check-input mt-0" type="radio" name="CorrectOptionIndex" id="editCorrectOption@i" value="@i" /></span>
                        </div>
                    }
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Cập nhật</button></div>
            </form>
        </div>
    </div>
}

<partial name="_DeleteConfirmationModal" />

@section Scripts {
    <script>
        async function loadQuestionForEdit(id) {
            const response = await fetch(`@Url.Action("GetForEdit", "Questions")?id=${id}`);
            if (!response.ok) {
                alert('Không thể tải thông tin câu hỏi để chỉnh sửa.');
                return;
            }
            const question = await response.json();
            document.getElementById('editQuestionId').value = question.id;
            document.getElementById('editQuestionSubjectId').value = question.subjectId;
            document.getElementById('editQuestionDifficulty').value = question.difficulty || 'Easy';
            document.getElementById('editQuestionStatus').value = question.status || 'Active';
            document.getElementById('editQuestionContent').value = question.content || '';
            document.getElementById('editQuestionExplanation').value = question.explanation || '';
            const optionsByLabel = new Map((question.options || []).map(option => [option.label, option]));
            for (let i = 0; i < 4; i++) {
                const label = String.fromCharCode(65 + i);
                const option = optionsByLabel.get(label);
                document.getElementById(`editOptionContent${i}`).value = option ? option.content : '';
                document.getElementById(`editCorrectOption${i}`).checked = option ? Boolean(option.isCorrect) : i === 0;
            }
            bootstrap.Modal.getOrCreateInstance(document.getElementById('editQuestionModal')).show();
        }
    </script>
}

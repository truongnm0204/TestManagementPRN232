@{
    ViewData["Title"] = "Tổng quan";
}

<div class="page-card p-4">
    <h1 class="h3 mb-3">TestManagement</h1>
    <p class="text-muted mb-4">Hệ thống quản lý bài test multiple choice.</p>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="row g-3">
            @if (User.IsInRole("Student"))
            {
                <div class="col-md-3">
                    <a asp-controller="MyExams" asp-action="Index" class="dashboard-card text-decoration-none d-flex align-items-center gap-3 p-3 border rounded-3 bg-white h-100">
                        <div class="dashboard-icon bg-primary bg-opacity-10 text-primary rounded-3 p-3">
                            <i class="bi bi-pencil-square fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Bài thi của tôi</div>
                            <small class="text-muted">Làm bài & xem kết quả</small>
                        </div>
                    </a>
                </div>
            }
            else
            {
            @if (User.IsInRole("Admin"))
            {
                <div class="col-md-3">
                    <a asp-controller="Users" asp-action="Index" class="dashboard-card text-decoration-none d-flex align-items-center gap-3 p-3 border rounded-3 bg-white h-100">
                        <div class="dashboard-icon bg-primary bg-opacity-10 text-primary rounded-3 p-3">
                            <i class="bi bi-people fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Người dùng</div>
                            <small class="text-muted">Quản lý tài khoản</small>
                        </div>
                    </a>
                </div>
                <div class="col-md-3">
                    <a asp-controller="Classes" asp-action="AdminIndex" class="dashboard-card text-decoration-none d-flex align-items-center gap-3 p-3 border rounded-3 bg-white h-100">
                        <div class="dashboard-icon bg-success bg-opacity-10 text-success rounded-3 p-3">
                            <i class="bi bi-building fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Lớp học</div>
                            <small class="text-muted">Quản lý lớp học</small>
                        </div>
                    </a>
                </div>
            }
            @if (User.IsInRole("Teacher"))
            {
                <div class="col-md-3">
                    <a asp-controller="Classes" asp-action="Index" class="dashboard-card text-decoration-none d-flex align-items-center gap-3 p-3 border rounded-3 bg-white h-100">
                        <div class="dashboard-icon bg-success bg-opacity-10 text-success rounded-3 p-3">
                            <i class="bi bi-building fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Lớp học</div>
                            <small class="text-muted">Lớp học của tôi</small>
                        </div>
                    </a>
                </div>
            }
            @if (!User.IsInRole("Teacher"))
            {
                <div class="col-md-3">
                    <a asp-controller="Subjects" asp-action="Index" class="dashboard-card text-decoration-none d-flex align-items-center gap-3 p-3 border rounded-3 bg-white h-100">
                        <div class="dashboard-icon bg-warning bg-opacity-10 text-warning rounded-3 p-3">
                            <i class="bi bi-book fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Môn học</div>
                            <small class="text-muted">Quản lý môn học</small>
                        </div>
                    </a>
                </div>
            }
            <div class="col-md-3">
                @if (User.IsInRole("Teacher"))
                {
                    <a asp-controller="Questions" asp-action="Packages" class="dashboard-card text-decoration-none d-flex align-items-center gap-3 p-3 border rounded-3 bg-white h-100">
                        <div class="dashboard-icon bg-danger bg-opacity-10 text-danger rounded-3 p-3">
                            <i class="bi bi-question-circle fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Câu hỏi</div>
                            <small class="text-muted">Câu hỏi của tôi</small>
                        </div>
                    </a>
                }
                else
                {
                    <a asp-controller="Questions" asp-action="Index" class="dashboard-card text-decoration-none d-flex align-items-center gap-3 p-3 border rounded-3 bg-white h-100">
                        <div class="dashboard-icon bg-danger bg-opacity-10 text-danger rounded-3 p-3">
                            <i class="bi bi-question-circle fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Câu hỏi</div>
                            <small class="text-muted">Quản lý câu hỏi</small>
                        </div>
                    </a>
                }
            </div>
            }
        </div>
    }
    else
    {
        <a asp-controller="Auth" asp-action="Login" class="btn btn-primary">Đăng nhập để bắt đầu</a>
    }
</div>

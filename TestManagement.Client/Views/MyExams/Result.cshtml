@model TestManagement.Client.Models.ExamAttempts.ExamResultViewModel
@{
    ViewData["Title"] = "Kết quả: " + Model.ExamTitle;
}

<div class="page-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h4 mb-1">Kết quả bài thi</h1>
            <p class="text-muted mb-0">@Model.ExamTitle</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index">Về danh sách</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center h-100"><div class="card-body">
                <div class="text-muted small">Điểm</div>
                <div class="h3 mb-0 text-primary">@Model.TotalScore / @Model.MaxScore</div>
            </div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100"><div class="card-body">
                <div class="text-muted small">Đúng</div>
                <div class="h3 mb-0 text-success">@Model.CorrectCount</div>
            </div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100"><div class="card-body">
                <div class="text-muted small">Sai</div>
                <div class="h3 mb-0 text-danger">@Model.WrongCount</div>
            </div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100"><div class="card-body">
                <div class="text-muted small">Bỏ qua</div>
                <div class="h3 mb-0 text-secondary">@Model.SkippedCount</div>
            </div></div>
        </div>
    </div>

    <p class="text-muted small">Nộp lúc: @Model.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</p>

    @if (!Model.Details.Any())
    {
        <div class="alert alert-info mb-0">Chi tiết bài làm chưa được công bố.</div>
    }
    else
    {
        @foreach (var d in Model.Details)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-semibold">
                            Câu @d.SortOrder
                            @if (d.IsCorrect == true)
                            {
                                <span class="badge text-bg-success ms-2">Đúng</span>
                            }
                            else if (d.SelectedOptionId == null)
                            {
                                <span class="badge text-bg-secondary ms-2">Bỏ qua</span>
                            }
                            else
                            {
                                <span class="badge text-bg-danger ms-2">Sai</span>
                            }
                        </span>
                        <span class="text-muted small">@(d.Score ?? 0) / @d.Points điểm</span>
                    </div>
                    <p class="mb-3">@d.Content</p>

                    <div class="options">
                        @foreach (var opt in d.Options)
                        {
                            var isSelected = d.SelectedOptionId == opt.OptionId;
                            var isCorrectOpt = Model.ShowCorrectAnswers && d.CorrectOptionIds.Contains(opt.OptionId);
                            var cssClass = isCorrectOpt ? "list-group-item-success"
                                         : (isSelected ? "list-group-item-danger" : string.Empty);
                            <div class="list-group-item @cssClass d-flex align-items-center mb-1 border rounded px-3 py-2">
                                <strong class="me-2">@opt.Label.</strong>
                                <span>@opt.Content</span>
                                @if (isSelected)
                                {
                                    <span class="badge text-bg-dark ms-auto">Bạn chọn</span>
                                }
                                else if (isCorrectOpt)
                                {
                                    <span class="badge text-bg-success ms-auto">Đáp án đúng</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>
